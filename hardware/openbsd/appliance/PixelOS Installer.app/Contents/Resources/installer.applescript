(*
PixelOS Installer — Application macOS graphique
Double-cliquez pour créer une clé USB bootable PixelOS
*)

-- Icône base64 (petit carré vert avec feuille)
property iconData : ""

-- Demander le mot de passe admin
set thePassword to text returned of (display dialog "
PixelOS Installer va créer une clé USB bootable.

Vous aurez besoin de:
• Une clé USB (8 Go minimum)

Entrez votre mot de passe administrateur:" with title "PixelOS Installer" with icon caution default answer "" buttons {"Annuler", "Continuer"} default button "Continuer" with hidden answer)

if thePassword is "" then
    display dialog "Installation annulée." with title "PixelOS Installer" buttons {"OK"} default button "OK"
    return
end if

-- Trouver l'installateur shell
set scriptPath to POSIX path of (path to me) & "Contents/Resources/install_pixelos_mac.sh"

-- Exécuter avec les droits admin
set result to do shell script "echo " & quoted form of thePassword & " | sudo -S -p '' " & quoted form of scriptPath with administrator privileges

if result contains "prête" or result contains "terminée" then
    display dialog "
✅ Installation terminée !

La clé USB PixelOS est prête.

Redémarrez le Mac en maintenant la touche Option (⌥) pour démarrer sur la clé USB.

🌱 Bienvenue dans la communauté PixelOS !" with title "PixelOS Installer" buttons {"OK"} default button "OK" with icon note
else
    display dialog "⚠️ " & result with title "PixelOS Installer" buttons {"OK"} default button "OK"
end if
