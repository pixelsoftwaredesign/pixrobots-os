        "z": "agricol-root",
        "name": "Cmd Verger",
        "topic": "",
        "qos": "1",
        "broker": "mqtt-broker",
        "x": 880,
        "y": 360,
        "wires": []
    },
    {
        "id": "dashboard-debit",
        "type": "ui_text",
        "z": "agricol-root",
