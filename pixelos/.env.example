# PixelOS - Variables d'environnement
# Copier vers /etc/pixelos/.env ou ./.env

# Base de données
MYSQL_PASSWORD=changeme
MONGO_URI=mongodb://localhost:27017/agricol_ts

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883

# Serveur
PIXELOS_NODE_ID=ferme_principale
PIXELOS_ROLE=server
PIXELOS_WEB_PORT=9999

# Backend Spring Boot
BACKEND_API_URL=http://localhost:8080/api

# Alertes
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_SERVER=
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=admin@agricol.local

# Sécurité
PIXELOS_SECRET_KEY=generate-a-random-key-here
