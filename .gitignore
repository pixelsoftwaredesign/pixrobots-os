# PixelOS / AgriCol - .gitignore

# Environnement
.env
.env.local
*.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/

# Java / Maven
target/
*.class
*.jar
*.war
*.log
.mvn/

# IDE
.idea/
*.iml
.vscode/
.project
.classpath
.settings/

# Node-RED
node_modules/

# Arduino
build/
*.elf
*.hex

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Backup
*.tar.gz
*.bak
*.old

# Logs
*.log
/var/log/

# ML models (regenerate with: pixelos predict train)
pixelos/models/
!pixelos/models/.gitkeep

# PixelOS logs
pixelos/logs/
pixelos/pixelos-agent.bat
pixelos/data/

# Backup directories with long paths
pixelos/src/.backups/
